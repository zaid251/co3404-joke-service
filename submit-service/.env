# ─── App Config ─────────────────────────────────────────
PORT=3002
NODE_ENV=development

# ─── RabbitMQ ───────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ─── Joke Service URL (for fetching types) ───────────────
JOKE_SERVICE_URL=http://localhost:3001

# ─── Types cache file path ───────────────────────────────
TYPES_CACHE_PATH=./cache/types.json

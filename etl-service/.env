# ─── App Config ─────────────────────────────────────────
PORT=3004
NODE_ENV=development

# ─── Database Mode (MYSQL or MONGO) ─────────────────────
DB_MODE=MYSQL

# ─── MySQL Config ───────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=jokeuser
MYSQL_PASSWORD=jokepass123
MYSQL_DATABASE=jokesdb

# ─── MongoDB Config ─────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/jokesdb

# ─── RabbitMQ ───────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
